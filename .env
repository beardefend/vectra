# ChromaDB Multi-Tenant Middleware - Environment Configuration
# Copy this file to .env and modify the values as needed

# ====================
# ADMIN CONFIGURATION
# ====================
# Admin API key for administrative endpoints (change this in production!)
ADMIN_API_KEY=a_key_strong

# ====================
# DATABASE PATHS
# ====================
# SQLite database file path (persistent)
SQLITE_DB_PATH=/app/data/sqlite/clients.db

# ChromaDB persistent storage directory (persistent)
CHROMADB_PATH=/app/data/chroma

# ====================
# APPLICATION CONFIGURATION
# ====================
# Freshness threshold in days (default: 7)
FRESHNESS_THRESHOLD_DAYS=7

# Server port (default: 8000)
PORT=8000

# Server host (default: 0.0.0.0 for Docker)
HOST=0.0.0.0

# ====================
# DOCKER VOLUME MAPPING
# ====================
# For docker-compose, data will be stored in:
# - ./data/sqlite for SQLite database
# - ./data/chroma for ChromaDB files
# These directories will persist across container restarts
